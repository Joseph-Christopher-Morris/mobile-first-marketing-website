{
  "mcpServers": {
    "aws": {
      "command": "npx",
      "args": [
        "-y",
        "@rafalwilinski/aws-mcp"
      ],
      "env": {
        "AWS_REGION": "us-east-1"
      },
      "disabled": true,
      "autoApprove": []
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem"
      ],
      "env": {
        "MCP_FILESYSTEM_ROOT": "."
      },
      "disabled": false,
      "autoApprove": [
        "write_file",
        "list_allowed_directories",
        "get_file_info",
        "search_files"
      ]
    },
    "lighthouse": {
      "command": "npx",
      "args": [
        "-y",
        "@danielsogl/lighthouse-mcp"
      ],
      "disabled": true,
      "autoApprove": []
    }
  }
}