{
  "mcpServers": {
    "aws": {
      "command": "npx",
      "args": [
        "-y",
        "@rafalwilinski/aws-mcp"
      ],
      "env": {
        "AWS_REGION": "us-east-1"
      },
      "disabled": true,
      "autoApprove": []
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem"
      ],
      "env": {
        "MCP_FILESYSTEM_ROOT": "."
      },
      "disabled": false,
      "autoApprove": [
        "write_file",
        "list_allowed_directories"
      ]
    },
    "lighthouse": {
      "command": "npx",
      "args": [
        "-y",
        "@danielsogl/lighthouse-mcp"
      ],
      "disabled": true,
      "autoApprove": []
    },
    "postman": {
      "transport": "sse",
      "url": "https://mcp.postman.com/minimal",
      "headers": {
        "Authorization": "Bearer ${POSTMAN_API_KEY}"
      },
      "disabled": true,
      "autoApprove": []
    }
  }
}